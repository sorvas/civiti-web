{
  "name": "civica",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/inject-env-vars.js",
    "start": "ng serve",
    "start:dev": "node scripts/set-env.js --dev && node scripts/inject-env-vars.js && ng serve",
    "restore-placeholder": "node scripts/set-env.js --restore",
    "prebuild": "node scripts/inject-env-vars.js && node scripts/inject-api-key-simple.js",
    "build": "ng build",
    "postbuild": "node scripts/inject-api-key-html.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:Civica": "node dist/Civica/server/server.mjs",
    "supabase:link": "node scripts/supabase-link.js",
    "supabase:push": "npx supabase db push",
    "supabase:status": "npx supabase db remote status",
    "supabase:diff": "npx supabase db diff --schema storage"
  },
  "private": true,
  "engines": {
    "node": ">=20.11.1 <21.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@angular/common": "^19.2.14",
    "@angular/compiler": "^19.2.14",
    "@angular/core": "^19.2.14",
    "@angular/forms": "^19.2.14",
    "@angular/google-maps": "^19.2.19",
    "@angular/platform-browser": "^19.2.14",
    "@angular/platform-server": "^19.2.14",
    "@angular/router": "^19.2.14",
    "@angular/ssr": "^19.2.14",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/entity": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "@ngrx/store-devtools": "^19.2.1",
    "@supabase/supabase-js": "^2.54.0",
    "@tailwindcss/postcss": "^4.1.11",
    "browser-image-compression": "^2.0.2",
    "express": "^5.1.0",
    "glightbox": "^3.3.1",
    "ng-zorro-antd": "^19.3.1",
    "postcss": "^8.5.6",
    "rxjs": "~7.8.1",
    "tailwindcss": "^4.1.11",
    "tslib": "^2.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^19.2.14",
    "@angular/cli": "^19.2.14",
    "@angular/compiler-cli": "^19.2.14",
    "@types/express": "^5.0.1",
    "@types/google.maps": "^3.58.1",
    "@types/jasmine": "~5.1.4",
    "@types/node": "^22.10.2",
    "dotenv": "^17.2.1",
    "jasmine-core": "~5.7.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "less": "^4.4.0",
    "typescript": "~5.6.3"
  },
  "overrides": {
    "@supabase/supabase-js": {
      "@supabase/auth-js": "2.61.0"
    }
  }
}
